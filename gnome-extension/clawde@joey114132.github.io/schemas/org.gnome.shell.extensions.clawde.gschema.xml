<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.clawde" path="/org/gnome/shell/extensions/clawde/">
    <key name="speed" type="d">
      <default>1.0</default>
      <range min="0.4" max="2.5"/>
      <summary>Movement speed multiplier</summary>
    </key>
    <key name="size" type="d">
      <default>1.35</default>
      <range min="0.5" max="2.0"/>
      <summary>Sprite size multiplier</summary>
    </key>
    <key name="monitor" type="i">
      <default>-1</default>
      <range min="-1" max="8"/>
      <summary>Monitor to roam: -1 = all, 0 = first, 1 = second, …</summary>
    </key>
  </schema>
</schemalist>
